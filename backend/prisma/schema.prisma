generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  CITIZEN
  AGENT
  ENTITY_ADMIN
  ADMIN
  SUPER_ADMIN
}

enum InstitutionType {
  MAIRIE
  POLICE
  ONECI
  MINISTERE
}

enum EventStatus {
  EN_ATTENTE_VALIDATION
  VALIDE
  REJETE
}

enum Gender {
  MASCULIN
  FEMININ
}

enum Severity {
  LEGER
  GRAVE
  FATAL
}

enum IncidentStatus {
  OUVERT
  EN_COURS
  FERME
}

// ─── INSTITUTION ─────────────────────────────────────────────────────────────

model Institution {
  id        String          @id @default(uuid())
  name      String
  type      InstitutionType
  city      String?
  createdAt DateTime        @default(now()) @map("created_at")

  users User[]

  @@map("institutions")
}

// ─── USER (agents, admins, super_admin) ──────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  fullName      String    @map("full_name")
  role          Role      @default(AGENT)
  institutionId String?   @map("institution_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  institution   Institution? @relation(fields: [institutionId], references: [id])

  // Événements enregistrés par cet agent
  birthRecords              BirthRecord[]
  deathRecords              DeathRecord[]
  marriageRecords           MarriageRecord[]
  divorceRecords            DivorceRecord[]
  migrationRecords          MigrationRecord[]
  incidents                 SecurityIncident[]
  messages                  AgentMessage[]
  customaryMarriageRecords  CustomaryMarriageRecord[]
  outOfFacilityBirthRecords OutOfFacilityBirthRecord[]

  @@map("users")
}

// ─── CITIZEN ─────────────────────────────────────────────────────────────────

model Citizen {
  id          String      @id @default(uuid())
  nni         String      @unique  // Numéro National d'Identification
  email       String?     @unique
  passwordHash String?    @map("password_hash")
  fullName    String      @map("full_name")
  birthDate   DateTime?   @map("birth_date")
  gender      Gender?
  address     String?
  city        String?
  phone       String?
  status      String      @default("EN_ATTENTE_VALIDATION")
  validatedAt DateTime?   @map("validated_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("citizens")
}

// ─── BIRTH RECORD ────────────────────────────────────────────────────────────

model BirthRecord {
  id               String      @id @default(uuid())
  babyFirstName    String      @map("baby_first_name")
  babyLastName     String      @map("baby_last_name")
  gender           Gender
  birthDate        DateTime    @map("birth_date")
  birthTime        String?     @map("birth_time")
  weight           String?
  height           String?
  hospitalName     String?     @map("hospital_name")
  cityOfBirth      String      @map("city_of_birth")
  motherFullName   String      @map("mother_full_name")
  motherNni        String?     @map("mother_nni")
  motherProfession String?     @map("mother_profession")
  fatherFullName   String?     @map("father_full_name")
  fatherNni        String?     @map("father_nni")
  fatherProfession String?     @map("father_profession")
  doctorName       String?     @map("doctor_name")
  status           EventStatus @default(EN_ATTENTE_VALIDATION)
  agentId          String?     @map("agent_id")
  reviewedAt       DateTime?   @map("reviewed_at")
  createdAt        DateTime    @default(now()) @map("created_at")

  agent User? @relation(fields: [agentId], references: [id])

  @@map("birth_records")
}

// ─── DEATH RECORD ────────────────────────────────────────────────────────────

model DeathRecord {
  id             String      @id @default(uuid())
  deceasedName   String      @map("deceased_name")
  deceasedNni    String?     @map("deceased_nni")
  deathDate      DateTime    @map("death_date")
  deathPlace     String?     @map("death_place")
  cause          String?
  declarantName  String      @map("declarant_name")
  declarantNni   String?     @map("declarant_nni")
  status         EventStatus @default(EN_ATTENTE_VALIDATION)
  agentId        String?     @map("agent_id")
  reviewedAt     DateTime?   @map("reviewed_at")
  createdAt      DateTime    @default(now()) @map("created_at")

  agent User? @relation(fields: [agentId], references: [id])

  @@map("death_records")
}

// ─── MARRIAGE RECORD ─────────────────────────────────────────────────────────

model MarriageRecord {
  id              String      @id @default(uuid())
  spouse1Name     String      @map("spouse1_name")
  spouse1Nni      String?     @map("spouse1_nni")
  spouse2Name     String      @map("spouse2_name")
  spouse2Nni      String?     @map("spouse2_nni")
  marriageDate    DateTime    @map("marriage_date")
  marriagePlace   String?     @map("marriage_place")
  witnesses       Json?       @default("[]") @map("witnesses") // [{ name: string, nni?: string }]
  status          EventStatus @default(EN_ATTENTE_VALIDATION)
  agentId         String?     @map("agent_id")
  reviewedAt      DateTime?   @map("reviewed_at")
  createdAt       DateTime    @default(now()) @map("created_at")

  agent User? @relation(fields: [agentId], references: [id])

  @@map("marriage_records")
}

// ─── DIVORCE RECORD ──────────────────────────────────────────────────────────

model DivorceRecord {
  id            String      @id @default(uuid())
  spouse1Name   String      @map("spouse1_name")
  spouse2Name   String      @map("spouse2_name")
  divorceDate   DateTime    @map("divorce_date")
  courtName     String?     @map("court_name")
  status        EventStatus @default(EN_ATTENTE_VALIDATION)
  agentId       String?     @map("agent_id")
  reviewedAt    DateTime?   @map("reviewed_at")
  createdAt     DateTime    @default(now()) @map("created_at")

  agent User? @relation(fields: [agentId], references: [id])

  @@map("divorce_records")
}

// ─── MIGRATION RECORD ────────────────────────────────────────────────────────

model MigrationRecord {
  id              String      @id @default(uuid())
  citizenName     String      @map("citizen_name")
  citizenNni      String?     @map("citizen_nni")
  originCity      String      @map("origin_city")
  destinationCity String      @map("destination_city")
  migrationType   String      @map("migration_type") // INTERNE | INTERNATIONAL
  migrationDate   DateTime    @map("migration_date")
  status          EventStatus @default(EN_ATTENTE_VALIDATION)
  agentId         String?     @map("agent_id")
  reviewedAt      DateTime?   @map("reviewed_at")
  createdAt       DateTime    @default(now()) @map("created_at")

  agent User? @relation(fields: [agentId], references: [id])

  @@map("migration_records")
}

// ─── SECURITY INCIDENT ───────────────────────────────────────────────────────

model SecurityIncident {
  id               String         @id @default(uuid())
  type             String
  severity         Severity
  location         String
  latitude         Float?
  longitude        Float?
  description      String
  judicialFollowup Boolean        @default(false) @map("judicial_followup")
  status           IncidentStatus @default(OUVERT)
  reportedById     String?        @map("reported_by_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  reportedBy User? @relation(fields: [reportedById], references: [id])

  @@map("security_incidents")
}

// ─── AGENT MESSAGE ───────────────────────────────────────────────────────────

model AgentMessage {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  content   String
  fromAdmin Boolean  @default(false) @map("from_admin")
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")

  agent User @relation(fields: [agentId], references: [id])

  @@map("agent_messages")
}

// ─── CUSTOMARY MARRIAGE (Mariage Coutumier) ──────────────────────────────────

model CustomaryMarriageRecord {
  id              String      @id @default(uuid())
  spouse1Name     String      @map("spouse1_name")
  spouse1Nni      String?     @map("spouse1_nni")
  spouse1Village  String?     @map("spouse1_village")
  spouse2Name     String      @map("spouse2_name")
  spouse2Nni      String?     @map("spouse2_nni")
  spouse2Village  String?     @map("spouse2_village")
  marriageDate    DateTime    @map("marriage_date")
  ceremonyPlace   String      @map("ceremony_place")
  customaryChief  String?     @map("customary_chief")  // Chef coutumier
  dotDescription  String?     @map("dot_description")  // Description de la dot
  witnesses       Json?       @default("[]") @map("witnesses")
  status          EventStatus @default(EN_ATTENTE_VALIDATION)
  agentId         String?     @map("agent_id")
  reviewedAt      DateTime?   @map("reviewed_at")
  createdAt       DateTime    @default(now()) @map("created_at")

  agent User? @relation(fields: [agentId], references: [id])

  @@map("customary_marriage_records")
}

// ─── OUT-OF-FACILITY BIRTH (Naissance hors établissement) ────────────────────

model OutOfFacilityBirthRecord {
  id               String      @id @default(uuid())
  babyFirstName    String      @map("baby_first_name")
  babyLastName     String      @map("baby_last_name")
  gender           Gender
  birthDate        DateTime    @map("birth_date")
  birthPlace       String      @map("birth_place")  // Village, domicile, route...
  birthCircumstance String?    @map("birth_circumstance") // Domicile, champ, route...
  motherFullName   String      @map("mother_full_name")
  motherNni        String?     @map("mother_nni")
  fatherFullName   String?     @map("father_full_name")
  fatherNni        String?     @map("father_nni")
  declarantName    String      @map("declarant_name")
  declarantRelation String?    @map("declarant_relation")
  witnesses        Json?       @default("[]") @map("witnesses")
  status           EventStatus @default(EN_ATTENTE_VALIDATION)
  agentId          String?     @map("agent_id")
  reviewedAt       DateTime?   @map("reviewed_at")
  createdAt        DateTime    @default(now()) @map("created_at")

  agent User? @relation(fields: [agentId], references: [id])

  @@map("out_of_facility_birth_records")
}

// ─── CERTIFICATE REQUEST (Demande de certificat) ─────────────────────────────

enum CertificateType {
  EXTRAIT_NAISSANCE
  ACTE_MARIAGE
  ACTE_DECES
  CERTIFICAT_RESIDENCE
  CERTIFICAT_NATIONALITE
  CERTIFICAT_CELIBAT
  CASIER_JUDICIAIRE
}

enum CertificateStatus {
  EN_ATTENTE
  EN_TRAITEMENT
  PRET
  DELIVRE
  REJETE
}

model CertificateRequest {
  id              String            @id @default(uuid())
  citizenId       String?           @map("citizen_id")
  citizenName     String            @map("citizen_name")
  citizenNni      String?           @map("citizen_nni")
  type            CertificateType
  purpose         String?           // Motif de la demande
  status          CertificateStatus @default(EN_ATTENTE)
  referenceNumber String?           @unique @map("reference_number")
  processedBy     String?           @map("processed_by")
  deliveredAt     DateTime?         @map("delivered_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@map("certificate_requests")
}

// ─── HEALTH ALERT (Alerte sanitaire) ─────────────────────────────────────────

enum AlertSeverity {
  FAIBLE
  MODERE
  ELEVE
  CRITIQUE
}

enum AlertStatus {
  ACTIVE
  SURVEILLEE
  RESOLUE
}

model HealthAlert {
  id          String        @id @default(uuid())
  title       String
  type        String        // Epidémie, Contamination eau, Malnutrition...
  severity    AlertSeverity
  region      String
  city        String?
  description String
  affectedCount Int?        @map("affected_count")
  status      AlertStatus   @default(ACTIVE)
  reportedBy  String?       @map("reported_by")
  resolvedAt  DateTime?     @map("resolved_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@map("health_alerts")
}

// ─── SUPPORT TICKET ──────────────────────────────────────────────────────────

enum TicketPriority {
  FAIBLE
  NORMALE
  HAUTE
  URGENTE
}

enum TicketStatus {
  OUVERT
  EN_COURS
  RESOLU
  FERME
}

model SupportTicket {
  id          String         @id @default(uuid())
  submittedBy String?        @map("submitted_by")  // userId
  subject     String
  category    String         // Technique, Acte civil, Accès, Autre
  description String
  priority    TicketPriority @default(NORMALE)
  status      TicketStatus   @default(OUVERT)
  assignedTo  String?        @map("assigned_to")
  resolvedAt  DateTime?      @map("resolved_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@map("support_tickets")
}

// ─── AUDIT LOG (Module 15 — Administration & Audit) ──────────────────────────

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  VALIDATE
  REJECT
  ACCESS_DENIED
}

model AuditLog {
  id           String      @id @default(uuid())
  userId       String?     @map("user_id")       // Qui a fait l'action
  userEmail    String?     @map("user_email")
  userRole     String?     @map("user_role")
  action       AuditAction
  resource     String                             // Ex: "BirthRecord", "Citizen", "User"
  resourceId   String?     @map("resource_id")   // ID de la ressource concernée
  description  String?                            // Détail lisible
  ipAddress    String?     @map("ip_address")
  userAgent    String?     @map("user_agent")
  metadata     Json?       @default("{}")         // Données supplémentaires (avant/après)
  createdAt    DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── API KEY (Module 16 — Exports & API Partenaires) ─────────────────────────

enum ApiKeyStatus {
  ACTIVE
  SUSPENDED
  REVOKED
  EXPIRED
}

model ApiKey {
  id            String       @id @default(uuid())
  name          String                             // Nom du partenaire / usage
  keyHash       String       @unique @map("key_hash") // Hash de la clé (jamais en clair)
  keyPrefix     String       @map("key_prefix")   // Préfixe visible ex: "rci_live_xxxx"
  organizationName String?   @map("organization_name")
  contactEmail  String?      @map("contact_email")
  permissions   Json         @default("[]")        // ["read:births", "read:deaths", ...]
  rateLimit     Int          @default(1000) @map("rate_limit") // Requêtes/heure
  status        ApiKeyStatus @default(ACTIVE)
  expiresAt     DateTime?    @map("expires_at")
  lastUsedAt    DateTime?    @map("last_used_at")
  createdBy     String?      @map("created_by")   // userId admin
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  usageLogs ApiKeyUsageLog[]

  @@map("api_keys")
}

model ApiKeyUsageLog {
  id        String   @id @default(uuid())
  apiKeyId  String   @map("api_key_id")
  endpoint  String
  method    String
  status    Int      // HTTP status code
  createdAt DateTime @default(now()) @map("created_at")

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id])

  @@index([apiKeyId])
  @@index([createdAt])
  @@map("api_key_usage_logs")
}
