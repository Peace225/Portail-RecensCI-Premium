{
  "expo": {
    "name": "RecensCI",
    "slug": "recensci",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#020617"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#020617"
      },
      "package": "ci.recensci.app",
      "versionCode": 1
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-asset"
    ]
  }
}
