        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#020617"
      },
      "package": "ci.recensci.app",
      "versionCode": 1
    },
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ],
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "5d355430-3d23-407a-83d5-6f22a5a4a152"
      }
    }
  }
}
